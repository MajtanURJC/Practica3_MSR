<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="wheels">

    <!-- Estructura lateral izquierda -->
    <link name="Left_Main_link">
      <visual>
        <origin xyz="-0.35 0 -0.25" rpy="3.14 0.55 3.14"/>
        <geometry>
          <mesh filename="package://practica3/meshes/dae/Cube.001.dae"
                scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="-0.35 0 -0.25" rpy="3.14 0.55 3.14"/>
        <geometry>
          <mesh filename="package://practica3/meshes/dae/Cube.001.dae"
                scale="1.0 1.0 1.0"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia
          ixx="0.20056"
          ixy="0.0"
          ixz="0.29280"
          iyy="2.04375"
          iyz="0.0"
          izz="1.87180"/>
      </inertial>
    </link>

    <joint name="Left_Main_link_joint" type="fixed">
      <parent link="base_link"/>
      <child link="Left_Main_link"/>
      <origin xyz="-0.2 -0.9 -0.5" rpy="0 0 0"/>
    </joint>

    <!-- Brazo trasero izquierdo -->
    <link name="Left_Rear_2_link">
      <visual>
        <origin xyz="0.4 0 0" rpy="1.5708 0 -0.27"/>
        <geometry>
          <mesh filename="package://practica3/meshes/dae/Cube.010.dae"
                scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0.4 0 0" rpy="1.5708 0 -0.27"/>
        <geometry>
          <mesh filename="package://practica3/meshes/dae/Cube.010.dae"
                scale="1.0 1.0 1.0"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="3.0"/>
        <inertia
          ixx="0.02064"
          ixy="0.0"
          ixz="-0.00874"
          iyy="0.53718"
          iyz="0.0"
          izz="0.52139"/>
      </inertial>
    </link>

    <joint name="Left_Rear_2_link_joint" type="fixed">
      <parent link="Left_Main_link"/>
      <child link="Left_Rear_2_link"/>
      <origin xyz="-0.7 -0.2 -0.6" rpy="1.5708 0 0"/>
      <!-- <axis xyz="0 0 1"/> -->
      <!-- <limit lower="-1.57" upper="1.57" effort="1000" velocity="20"/> -->
    </joint>

    <!-- Rueda delantera izquierda -->
    <link name="Front_Left_Tire_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://practica3/meshes/dae/Cylinder.001.dae"
                scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://practica3/meshes/dae/Cylinder.001.dae"
                scale="1.0 1.0 1.0"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.000000</mu>
              <mu2>1.000000</mu2>
              <fdir1>0.000000 0.000000 1.000000</fdir1>
              <slip1>0.0050000</slip1>
              <slip2>0.0050000</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="2.0"/>
        <inertia
          ixx="0.05138"
          ixy="0.0"
          ixz="0.0"
          iyy="0.08942"
          iyz="0.0"
          izz="0.05138"/>
      </inertial>
    </link>

    <joint name="Front_Left_Tire_link_joint" type="continuous">
      <parent link="Left_Main_link"/>
      <child link="Front_Left_Tire_link"/>
      <origin xyz="1.45 -0.2 -0.7" rpy="1.5708 0 0"/>
      <axis xyz="0 0 -1"/>
    </joint>

    <transmission name="front_left_trans">
      <type>transmission_interface/SimpleTransmission</type>
        <joint name="Front_Left_Tire_link_joint">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        </joint>
      <actuator name="front_left_motor">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <gazebo reference="Front_Left_Tire_link">
        <mu1>5</mu1>
        <mu2>5</mu2>
        <!--kp>2.75e6</kp>
        <kd>8.25e1</kd>
        <fdir1>0 0 0</fdir1>
        <maxContacts>4</maxContacts-->
    </gazebo>

