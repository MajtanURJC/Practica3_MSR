<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="robot_arm">

  <!-- ARM 1 -->
  <link name="Arm1_link">
    <visual>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.008.dae"
              scale="0.1 0.1 0.85"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.008.dae"
              scale="0.1 0.1 0.85"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.35823" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia
        ixx="0.89612"
        ixy="0.0"
        ixz="0.0"
        iyy="0.89612"
        iyz="0.0"
        izz="0.53844"/>
    </inertial>
  </link>

  <joint name="Arm1_link_joint" type="fixed">
    <parent link="Body_link"/>
    <child link="Arm1_link"/>
    <origin xyz="0.6 0 -0.35"/>
  </joint>


  <!-- ARM 2 -->
  <link name="Arm2_link">
    <visual>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.009.dae"
              scale="0.75 0.15 0.1"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.009.dae"
              scale="0.75 0.15 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.54878 0 0" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia
        ixx="0.03414"
        ixy="-0.00071"
        ixz="-0.00072"
        iyy="0.80029"
        iyz="0.0"
        izz="0.80928"/>
    </inertial>
  </link>

  <joint name="Arm2_link_joint" type="revolute">
    <parent link="Arm1_link"/>
    <child link="Arm2_link"/>
    <origin xyz="0 0 1.65"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="100" velocity="5.0"/>
  </joint>

  <transmission name="Arm2_link_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="Arm2_link_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="Arm2_link_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>


  <!-- ARM 3 -->
  <link name="Arm3_link">
    <visual>
      <origin xyz="0.65 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.010.dae"
              scale="0.75 0.15 0.1"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0.65 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.010.dae"
              scale="0.75 0.15 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.60122 0 0" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia
        ixx="0.03414"
        ixy="-0.00071"
        ixz="0.00072"
        iyy="0.80029"
        iyz="0.0"
        izz="0.80928"/>
    </inertial>
  </link>

  <joint name="Arm3_link_joint" type="revolute">
    <parent link="Arm2_link"/>
    <child link="Arm3_link"/>
    <origin xyz="1.15 0 0.2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.3" upper="2.3" effort="10" velocity="5.0"/>
  </joint>

  <transmission name="Arm3_link_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="Arm3_link_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="Arm3_link_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>


  <!-- ARM 4 -->
  <link name="Arm4_link">
    <visual>
      <origin xyz="0 0 -0.35" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.007.dae"
              scale="0.1 0.1 0.75"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 -0.35" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.005.dae"
              scale="0.1 0.1 0.75"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="0.11786"
        ixy="0.0"
        ixz="0.0"
        iyy="0.11786"
        iyz="0.0"
        izz="0.00994"/>
    </inertial>
  </link>

  <joint name="Arm4_link_joint" type="revolute">
    <parent link="Arm3_link"/>
    <child link="Arm4_link"/>
    <origin xyz="1.15 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="5"/>
  </joint>

  <transmission name="Arm4_link_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="Arm4_link_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="Arm4_link_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>


  <!-- EXTENSOR -->
  <link name="Extensor_link">
    <visual>
      <origin xyz="0 0 0.41" rpy="3.14159 0 3.14159"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.011.dae"
              scale="0.075 0.075 0.5"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.41" rpy="-3.14159 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cylinder.011.dae"
              scale="0.075 0.075 0.5"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.00147" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="0.13344"
        ixy="0.0"
        ixz="0.0"
        iyy="0.13344"
        iyz="0.0"
        izz="0.01688"/>
    </inertial>
  </link>

  <joint name="Extensor_link_joint" type="prismatic">
    <parent link="Arm4_link"/>
    <child link="Extensor_link"/>
    <origin xyz="0 0 -0.84" rpy="3.14159 0 3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.25" upper="0.85" effort="200" velocity="5.0"/>
  </joint>

  <transmission name="Extensor_link_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="Extensor_link_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="Extensor_link_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>


  <!-- GRIPPER LEFT -->
  <link name="Garra_Left_link">
    <visual>
      <origin xyz="0 0 -0.1" rpy="3.14159 0 3.14159"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cube.008.dae"
              scale="0.05 0.05 0.25"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cube.008.dae"
              scale="0.05 0.05 0.25"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="0.04333"
        ixy="0.0"
        ixz="0.0"
        iyy="0.04333"
        iyz="0.0"
        izz="0.00333"/>
    </inertial>
  </link>

  <joint name="Garra_Left_link_joint" type="prismatic">
    <parent link="Extensor_link"/>
    <child link="Garra_Left_link"/>
    <origin xyz="0 -0.4 1.31" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.11" effort="200" velocity="5.0"/>
  </joint>

  <transmission name="Garra_Left_link_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="Garra_Left_link_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="Garra_Left_link_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>


  <!-- GRIPPER RIGHT -->
  <link name="Garra_Right_link">
    <visual>
      <origin xyz="0 0 -0.1" rpy="3.14159 0 3.14159"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cube.007.dae"
              scale="0.05 0.05 0.25"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://practica3/meshes/dae/Cube.007.dae"
              scale="0.05 0.05 0.25"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="0.04333"
        ixy="0.0"
        ixz="0.0"
        iyy="0.04333"
        iyz="0.0"
        izz="0.00333"/>
    </inertial>
  </link>

  <joint name="Garra_Right_link_joint" type="prismatic">
    <parent link="Extensor_link"/>
    <child link="Garra_Right_link"/>
    <origin xyz="0 0.4 1.31" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.11" effort="200" velocity="5.0"/>
  </joint>

  <transmission name="Garra_Right_link_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="Garra_Right_link_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="Garra_Right_link_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

</xacro:macro>

</robot>